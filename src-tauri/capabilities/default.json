{
  "$schema": "https://raw.githubusercontent.com/nicegoodtimeenjoyer/tauri-v2-capabilities-schema/main/schema.json",
  "identifier": "default",
  "description": "Default capabilities for Markora",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "dialog:allow-save"
  ]
}
