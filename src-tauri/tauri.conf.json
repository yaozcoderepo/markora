{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Markora",
  "version": "0.1.0",
  "identifier": "com.markora.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Markora",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300
      }
    ]
  }
}
